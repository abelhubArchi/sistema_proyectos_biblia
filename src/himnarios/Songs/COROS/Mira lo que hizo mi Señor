<song>
  <title>Mira lo que hizo mi Señor</title>
  <lyrics>[V1]
 //Mira lo que hizo mi Señor//
 //me levanto y me libero
 mira lo que hizo mi Señor//

[V2]
 //caminando por la senda voy,//
 //de prueba en prueba,victoria tras
           victoria,
 caminando por la senda voy//

[V3]
 //El enemigo ya vencido esta//
 //Jesús lo vencio muriendo en la cruz
 ¡El enemigo ya vencido está!//                  
 </lyrics>

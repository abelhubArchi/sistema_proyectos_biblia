  <lyrics>[V1]
 //Tengo gozo en mi alma//
 Con mi Jesús.
 
[V2]
 //Gloria a Dios, aleluya,//
 Para siempre.
 
[V3]
 //Jesucristo pronto viene//
 A llevarme.
 
[V4]
 //El me dará recompensa//
 En el cielo.
 

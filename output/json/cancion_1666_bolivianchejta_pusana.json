  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Bolivianchejta pusana Cristoman",
        "Dios Tatanchejpa ñanninman.",
        "Evangeliota apaspa runasman,",
        "Juchayojkunaman willaspa./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Señor Jesús kamacherqa",
        "Willananchejta Pay manta,",
        "Tukuy Kay pachapi kashaj runasman",
        "Payllapi salvación kasqanta./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Mana atispa qan willamuytaqa",
        "Bolivianchejpi runasman,",
        "Ofrendawan yanapawaj, hermanóy,",
        "Obreros willaj rinankupaj./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Kay suyunchejpi ashkhasmin kashanku",
        "Cristota mana rejsispa.",
        "Qan, willaj mana rejtíyki, hermanóy,",
        "Imaynamanta yachaqanku?"
      ]
    }
  ]
}
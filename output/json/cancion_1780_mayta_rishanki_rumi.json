      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Mayta rishanki rumi sonqo runa,",
        "Qonqarpariwaspa, qonqaj sonqo runa?",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Jinata rispaqa, yvañuyUaman rinki.",
        "Juchasniyki\\vanqa ninallaman rinki.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Qhawarimuway, qayllaykipi kani.",
        "Kutimpuway ari, Salvajniyki kani.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Creewaspaqa, sonqoykita qoway.",
        "Qhatiwanki chayqa, ñannillayta rinki.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Kutimusajña, pusakapusqayki",
        "Wiñay kusikuypi kawsakunaykipaj."
      ]
    }
  ]

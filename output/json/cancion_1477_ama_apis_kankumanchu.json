  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Amañapis kankumanchu sirvisojkuna Qantaqa,",
        "Sapallaypis sirvisqayki Iglesiapi, mayllapipis./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Dios Tatáy, yanapariway chayjatun atiyniykiwan.",
        "Qanllata sirvikusqayki cieloman ripunaykama./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Ama ari, sayk'uymanchu sirvikusuyta, Dios Tatáy.",
        "Kamachiwasqasniykita junfayta yanapariway./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Tukuy sonqo sirvisuyta yanapariway, Dios Tatáy.",
        "Qanllamin salvawarqanki chay yawarjich'asqaykiwan/"
      ]
    }
  ]
}
  "referencias_biblicas": [],
  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Esta vida terrenal,",
        "Está llena de dolor,",
        "De angustias y pruebas mil;",
        "De infelicidad.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Cristo el Señor, pronto volverá,",
        "A llevarnos ya al celeste hogar;",
        "Esperemos hoy, con paciencia y fe,",
        "Triunfantes al mal, y al vil Tentador.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Los falsos maestros aún,",
        "Se levantan más y más.",
        "Engañando cada vez",
        "A los del Señor.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "El horror de la maldad,",
        "Se acrecienta más y más;",
        "Los que siguen al Señor,",
        "Se vuelven atrás.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "La advertencia del Señor,",
        "Para sus hijos de luz,",
        "Es que le sigamos fiel",
        "Hasta el final."
      ]
    }
  ]
}
  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Cuando en las tinieblas yo vagaba,",
        "Jesús es la luz que me rescató./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Si en Cristo no buscaba",
        "La salvación de mi alma,",
        "Iba a perecer eternamente./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Por tu senda de luz yo andaré.",
        "Sólo para Tí podré yo vivir./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Vengo a tus pies, oh bendito Dios,",
        "En tus brazos ya podré descansar./"
      ]
    }
  ]
}
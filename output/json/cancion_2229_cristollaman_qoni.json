      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Cristollaman qoni tukuy kawsayniyta.",
        "Payllamin noqata salvakuwarqa./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Cristolla tiyakun Sonqoy ukhupeqa",
        "Wiñay wiñaypaj./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Yupaychana Diosta kutímunankama;",
        "Pusakapuwasun mosoj llajtanman./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Diosta qhesachajqa wañuyilaman renqa.",
        "Jesusllapi tiyan jatun salvación./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "/Tukuy bendiciompis Jesusmanta jamun.",
        "Tukuynin wawasnin yupaychanachej./"
      ]
    }
  ]

      "lineas": [
        "Salvasojniykita tarinkiñachu?",
        "Yawarninta Payjich’arqa qanrayku.",
        "Chimpankiñachu Salvasojniykiman",
        "Yawarninwan mayllanasumpaj?",
        ""

        "Tuikuy juchastapis saqenkiñachu",
        "Yawarninwan mayllanasumpaj?",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Juchasniykitapis Pay llimphuchanqa.",
        "Yawarninta Payjich’arqa qanrayku.",
        "Nina larwaypi ñak’ariymantapis",

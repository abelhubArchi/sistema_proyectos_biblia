      "numero": 1,
      "lineas": [
        "¿A DONDE IRE SIN TI SEÑOR?",
        "SI SOLO TU SEÑOR TIENES",
        "PALABRAS DE VIDA",
        "SI SUBIERA AL MONTE MAS ALTO O",
        "BAJARA HASTA EL FONDO DEL MAR",
        "¿QUIEN ME DARA,",
        "QUIEN ME MOSTRARA TAL AMOR?",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "DANZARE, CANTARE DERRAMARE",
        "MI CORAZÓN DELANTE DE TI",
        "ES EL RIO DE TU AMOR.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "TANTOS AÑOS YO PERDI",
        "SIN EL AMOR QUE NO PUDE VER",
        "HASTA QUE ENCONTRE",
        "LA PRESENCIA DE DIOS",
        "AQUI EN EL RIO."
      ]
    }
  ]

      "lineas": [
        "\"Mañakuway, uyarisqayki, mañakuway,",
        "Yachachisqayki",
        "Mana atínki chay imasta\". Chayta nishan Dios.",
        "Amataj iskayrayaspa mañakuna bendicionninta.",
        "Atipasun mañakuspa. Gloria Diosman."
      ]

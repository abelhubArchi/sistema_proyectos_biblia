      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Qhitirac nayar apaketaspa Diosan amparapat.",
        "Atipjirinac taypin nayajja jicjjatasiñ munta.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        ":Alajjpacharuw sarascta",
        "Kori marcaruw sarascta",
        "Wiñayataqui. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Warank warank angelanacawa Diosarojj k'ochupjje.",
        "Jupanacampi chicaraquiwa jicjjatasiñ munta.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Ñankha Supayan amtatapajja mamayataquiw.",
        "Jachañarusa jiwañarusa janiw ajjsarcáti.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Cunarac nayar camachitaspa cusisitaw sará.",
        "Janiw sapácti. Diosaw nayampi. jupaw irpasquitu."
      ]
    }
  ]

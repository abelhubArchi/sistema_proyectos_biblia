      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Qhititejj tucuycam sayt'añani",
        "Ucaquiw khespiyat ufijasiñän.",
        "Qhititejj jiwañcam arcañáni",
        "Wiñay jacañwa catokañän.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Kollan Ajayum qhitanim Tata,",
        "Nayar ch'aman tuct'ayit.",
        "Jumaruquiwa nayajj alcatsma",
        "Take chuymajjampi. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Qhititejj take chuym Cristompiñan",
        "Ucaruw Tatitojj yanapistan.",
        "Take ch'aman Tatit Jesusawa",
        "Yant'ar atipan yanapistan.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "¿Cristor uñtcatañti jumajj numta?",
        "Jan páchasisay Cristompi saram.",
        "¿Alajjpacharuti puriñ munta?",
        "Ch'amanchasimay tucuycama."
      ]
    }
  ]

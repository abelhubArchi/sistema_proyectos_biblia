  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Kollana Cristo yanapt'asiquitay,",
        "Jumaquitawa nayataquejja cheka Diosajj. Tata.",
        "Nayataquejj janiw cawqhans utjquiti,",
        "Usut kollir, jiwat sartayiri, reyins Reyipátaw.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Jacht'asisawa sarnakascáyát,",
        "Uqham sarnakquiriruwa:",
        "\"Nayar jutjjam\" sista.",
        "Cunampiquisa nayajj phokháma,",
        "Jumaruquiw nayajj sirvim",
        "Marcamar puriñcam.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Kollana Cristo yanapt'asiquitay,",
        "Cunayman llaquiw nayatac sarti, atipt'ayitaya.",
        "Mayninacas kheparuwa cutt'jjapjje,",
        "Janiquiya antutfasistati, qhuyapt'ayasitay.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Kollana Cristo yanapt'asiquitay,",
        "Juman altaramaruwa jutta, catokt'asiquitay.",
        "Acá chuymajj jank'o qhunur uñtatay",
        "Nayrakatamanjj tuct'ayasita, wiñay Dios Awquejja."
      ]
    }
  ]
}
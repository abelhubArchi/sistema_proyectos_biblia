      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Cristianonacajj amtapjjañáni",
        "Qhá jach'a musparcaña uruta.",
        "Cristojj janchir tucus jutatapat",
        "Cusisifián take chuymampi.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Jichhürojj k'ochuñán Jesusaru",
        "Jupaw khespiyasiñ apanistu.",
        ":Sutiparu yupaychapjjañani",
        "Khespiyatanacapajj. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Belén marcan Cristojj naciwayi",
        "Khespiyasina utjayasina.",
        "Profetanacan arsutapajja",
        "Phokhasiw jupan jutáwipamp.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Dios Awquejj munasifiap churistu",
        "Cristo Jesusar qhitanisajja.",
        "Machak yatiyáw apayanistu",
        "Cusís iñaw takenitaqui."
      ]
    }
  ]

      "numero": 1,
      "lineas": [
        "Pagaste un alto precio por mí",
        "Ofreciste tu vida misma por mí,",
        "Me consolaste cuando mas necesite",
        "Como no voy a servirte, mi Señor.",
        "",
        "Permíteme elevarte adoración",
        "Entregarte hoy todo mi ser,",
        "Siempre, siempre, siempre te alabaré",
        "Toda mi vida Señor te adoraré."
      ]
    }
  ]

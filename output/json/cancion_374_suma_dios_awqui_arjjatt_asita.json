  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Suma. Dios Tata. nayaw jaltanta,",
        "Qhuyapt' ayasitay;",
        "Cunayman llaquiw nayatac sarti",
        "Arjjatt'asiquitay.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Suma Dios Awqui arjjatt'asita,",
        "Jan walfafi taypina;",
        "Cunjamatejja wallpajj arjjati.",
        "Chhiwchhinacaparu.",
        "Ch'amamampiya jarc'akasita",
        "Juman wawamátwa;",
        "Sapa urunsa imasitaya, munasir Awquejja.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Jumay sayfasim naya toketjja,",
        "Jach'a ch'amamampi;",
        "Jumjam ch'amanejj janiw utjquiti",
        "Wiñay Dios Awquejja.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Suma Dios Tata cusisitaqui,",
        "Nayar jacayita;",
        "Take llaquisiñanacajjansa",
        "Chuymachasiquitay."
      ]
    }
  ]
}
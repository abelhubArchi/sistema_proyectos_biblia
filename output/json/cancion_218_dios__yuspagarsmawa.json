      "numero": 1,
      "lineas": [
        "Dios yuspagarsmawa",
        "Nayar munatamat",
        "Take chuymajjampiw",
        "Jumar arcan munta.",
        ":Suma Dios Awquejja",
        "Nayar yatichitay",
        "Juman arunacam",
        "Parlañajjataqui. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Khespiyirisajja",
        "Cruzan jiwawayi.",
        "Juchanacas laycuw",
        "Wilap wartawayi.",
        ":Jumajj iyawsamay",
        "Cristojj perdonätam",
        "Take juchanacam",
        "K'oma wilapampi. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Cristojj mä uruwa",
        "Wastat cutinjjani",
        "¡Cunja sumänisa",
        "Jupar uñe ataña!",
        ":¿ Juman chuymamasti",
        "Juchat k'omachatat",
        "Jupamp sarjjañatac",
        "Alajjpach marcaru? (Bis)"
      ]
    }
  ]

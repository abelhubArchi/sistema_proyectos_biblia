  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Jach'a cancafiamajj musparcañaw Tatay,",
        "K'oma cancañamas wiñayaraquiwa.",
        "Kollan Dios Awquejja naya sirvirimar",
        "Uca k'oma cancán churaraquitaya.",
        ":K'omachitay Tata, ñankha jucha jjata",
        "K'oma chuymanrac tucfayita. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Kollan Ajayumamp chuymajjar phokt'ita",
        "Asqui luráwinac lurañajjataqui.",
        "Paciencianin munta, munasiñ chuymani",
        "Qhuyapayasiri. perdonir chuymani.",
        ":K'omachitay Tata, suma wilamampi",
        "Asqui cancafiamamp phokt’ita. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Janiw qhitis Tatay, jan k'oma chuymampejj",
        "Kollan Ajanumjja uficatafl puedcanit.",
        "Asqui jakenacaw ajanum. uñjapjjan",
        "Wiñayaraquiwa jumamp jacapjjani.",
        ":K'omachitay Tata. ñankha jucha jjata",
        "K'oma chuymanrac tucfayita. (Bis)"
      ]
    }
  ]
}
  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "El esplendor de un Rey, vestido en majestad,",
        "La tierra alegre está, La tierra alegre está.",
        "",
        "Cubierto está de luz, Venció la oscuridad",
        "Y tiembla a su voz, Tiembla a su voz,",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Coro:",
        "",
        "Cuán grande es Dios",
        "Cántale, cuán grande es Dios",
        "Y todos le verán,",
        "Cuán grande es Dios.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Día a día Él está, Y el tiempo está en Él,",
        "Principio y el fin, Principio y el fin.",
        "",
        "La trinidad en Dios, El Padre, Hijo, Espíritu",
        "Cordero y el león, Cordero y el león.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Y tu nombre sobre todo es, Tu eres digno de alabar,",
        "Y mi ser dirá, Cuán grande es Dios.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Mi corazón entona la canción",
        "¡Cuán grande es Él!",
        "¡Cuán grande es Él!"
      ]
    }
  ]
}
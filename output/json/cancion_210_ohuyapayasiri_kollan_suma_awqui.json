  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Qhuyapayasiri kollan suma Awqui",
        "Munasinamajja sinti jach'awa.",
        "Chhaktat unjasawa nayar khespiyista",
        "Winay cusisiña churanataqui.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Qhuyapayasiri jach'a Dios Awqui",
        "Unisirejjaru qhuyapt'ayamay.",
        "Inamayaquiwa jakes arusí",
        "Janiw chuymajjaru usuyquituti.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Uñisirinacajj utjapiniw Tata",
        "Juman thaquimansa cawqui chekansa.",
        "Ucampis nayajja cusisitapiniw",
        "Take chuymajjampi Jumar arcama.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Familianacajjas armapjjetuw Tata.",
        "Juma sapaquiwa uywthapisjjestajj.",
        "Waljaniraquiwa nayar c'umipjjetu",
        "¿Cunáis ajjsarájja? Khespiyatátwa."
      ]
    }
  ]
}
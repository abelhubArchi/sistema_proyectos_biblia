      "numero": 1,
      "lineas": [
        "Tatit Cristojja koliu patanjja.",
        "Kollan Arunacap,",
        "Take jakerus yatichawayi",
        "Sum jacafiataqui.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Diosan munafiap lurapjjafiáni,",
        "Sapakat maynisa;",
        "Take fiankhatsa jithektasina",
        "Jan mayampitaqui.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Janiw qhitinacatejj \"Tatay. Tatay\"",
        "Sapc ucanacajj,",
        "Alajjpacharu mantapcaniti",
        "Jupan jac'aparu.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Qhaya urunjja waljaninacaw",
        "Cristompffi munapjjan,",
        "ücampis Cristojj saraquiniwa:"
      ]
    }

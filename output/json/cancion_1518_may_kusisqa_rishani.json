  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/May kusisqa rishani janaj pachaman,",
        "Almastawan pusaspa Salvawajniyman./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Rikuytapuni munani Salvawajniyta.",
        "Jaqay k'anchaj llajtapi Payman takisaj./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/May kusisqa kashani Salvawajniywan.",
        "Paymin jatun Reyneyqa, Paypi suyani./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Tukuy tentacionespi noqawan kashan.",
        "Payqa k’anchawanipuni tukuy ñanniypi./"
      ]
    }
  ]
}
  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Khespiyir Cristo Awquisajja Kollan Ajayu qhitanistu,",
        "Jupar jaysirinacataqui.",
        ":Jnchanac khananchiriw juti cheka cancán apanisina",
        "Samarañan phokfat jacañsa. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Kollan Ajay catokañáni, jupaw thaquipan irpistani,",
        "Cheka cancafian sarnakañsa.",
        ":Yanfanacan yanapistani, thaquipans ch'amañchistaniwa,",
        "Janiw jupajj jaytquistaniti. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Kollan Ajayu laycuquiwa chuyma samarañjja churistu,",
        "Cusisiñsa almasataqui.",
        ":Awquisajj munasiñaniwa, munat sapa Yokap churistu,",
        "Kollan Ajaysa qhitanistu. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Kollan Ajayuw jiwasampi, jupar ajjsartas sarafiáni",
        "Juchanacas apanucusa.",
        ": Cheka arunacap isfasa take maynisa sarnakañan",
        "Kollan Ajays catokañáni. (Bis)"
      ]
    }
  ]
}
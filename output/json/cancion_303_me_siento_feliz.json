      "lineas": [
        "Me siento muy feliz,",
        "Me siento muy feliz,",
        "Porque el Señor Jesús",
        "Me dio la salvación.",
        ":Pedí perdón de Dios",
        "De todo corazón,",
        "Y El me perdonó",
        "De toda mi maldad. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Si tú no estás feliz",
        "Gozando en el Señor,",
        "Acude a Dios con fe",
        "Y El te salvará.",
        ":Pide perdón de Dios",
        "De todo corazón,",
        "Y El con tanto amor",
        "Tu mal perdonará. (Bis)"
      ]
    }
  ]

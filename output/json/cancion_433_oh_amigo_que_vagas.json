  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Oh amigo,",
        "Que muy triste vagas tú.",
        ":No hay otro como Cristo",
        "Que te ama y te busca",
        "Para tus pecados perdonar. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Otro nombre",
        "Dado a hombres no lo hay.",
        ":Solo Jesucristo salva",
        "Y perdona los pecados;",
        "Ven, recibe a tu Salvador. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Cada día,",
        "Dios te busca con amor.",
        ": Para darte vida nueva,",
        "Vida eterna en los cielos,",
        "Donde no habrá llanto, ni dolor. (Bis)"
      ]
    }
  ]
}
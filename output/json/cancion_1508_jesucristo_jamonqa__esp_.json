  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Cristo pronto volverá entre las nubes.",
        "Con su gloria y poder El descenderá./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/El sol, la luna oscurecerán.",
        "Todo el mundo tembrará, que dolor será./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/En la voz del arcángel, El nos llamará.",
        "A los que esperan a El pronto llevará./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Esperemos a Jesús sin más vacilar.",
        "Repentinamente nos sorprenderá./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "/Al que rechaza a Jesús, le juzgará El.",
        "A la muerte eternal le condenará./"
      ]
    }
  ]
}
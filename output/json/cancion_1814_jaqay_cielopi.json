      "lineas": [
        "Jaqay cielopi, qori llajtapi, janaj pachapi,",
        "Mana kanqachu Hakiykuna. waqaykunapis.",
        "Salvasqasña kajkunatajri Paywan ripusunchej;",
        "Yupaychamusun Señoría."
      ]

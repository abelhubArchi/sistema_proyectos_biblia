  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Dios Awquin acapacharu",
        "Wali munatap laycuwa,",
        "Mmat vawapar qhitxii,",
        "Jakenacar kheapiyaflatac.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Kollan Ajay tokequiwa",
        "Tatit Cristojj naciwayi",
        "Juchasat khespiyañataqui.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Angelajj Josearojj sánwa:",
        "\"Jesús\" sasaw suticháta,",
        "Jupaw take juchanacat",
        "Marcapar khespiyaraquini.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Ovej awatirinacar",
        "Má angelaw yatiyana:",
        "\"Jichhajj khespiyiriw nazjje",
        "Má uyun Belén sat marcaría\".",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Magonacaw Jesusaru",
        "Yupaychiri sarapjjána,",
        "Surna regalonacraqui",
        "Cusisit chuymamp churapjjána."
      ]
    }
  ]
}
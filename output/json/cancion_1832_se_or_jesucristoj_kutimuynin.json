  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Señor Jesucristoj kutimuynin qayllaña.",
        "Tutapis, p'unchaypis jamunanta suyana./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Chayrayku, hermano,",
        "Diosman qayllaykuna astawan./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Kunan tiempo kashan; hermanóy, chimpallayña.",
        "Señor Jesucristo yanaparillasonqa./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Tentación jamojtin, Señorman qayllaykuna.",
        "Señor Jesucristo yanaparillawasun./"
      ]
    }
  ]
}
  "referencias_biblicas": [],
  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Señor Jesusníy, pusaway makiymanta.",
        "Wawayki kani, chajraykipi llank’asaj./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Jaqay cielopi Dios Tataywan,",
        "Chaypi mñaypaj kusikusaj,",
        "Jesús qowanqa qoripilluta,",
        "Paywan wiñaypaj kawsamusaj.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Qanmin qowanki wiñay wiñay kawsayta.",
        "Qanwantaj k’anchay gloriaykipi kamusaj./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Tukuy sonqowan Qanta yupaychasqayki",
        "Jatun salvacionta qowasqaykimanta./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "/Juchasniymanta perdonaway, Dios Tatáy.",
        "Llimphu kawsaypi Qanllata sirvisqayki./"
      ]
    }
  ]
}
  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Alma querida en donde vagas,",
        "En las tinieblas te vas a perder./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "No tienes excusa, no tienes perdón.",
        "No tienes franca, las puertas de Dios.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Si Jesucristo viniera este día,",
        "¿Cual es tu excusa que vas a decir?/",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Hoy te invitamos, oh vil pecador,",
        "En Jesucristo hallarás el perdón./"
      ]
    }
  ]
}
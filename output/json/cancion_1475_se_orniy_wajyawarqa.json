  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Señorniy wajyawarqa chajrampi llank'anaypaj.",
        "Kunan Ilakisqa kani mana llank'asqay manta.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Chajranqa may jatunmin, llank’ajkunarí pisi.",
        "Usqhayta llak'anachej; Señorqa jamonqaña./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Willasaj Señormanta, kasuspa niwasqanta.",
        "Kunan kasukuy ari, mana qhellakuspalla.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Cristopaj llank'ajkuna finkatajap’enqanku.",
        "Ancha kusikuy kanqa, Señor kutimojtenqa"
      ]
    }
  ]
}
      "numero": 1,
      "lineas": [
        "Juma jac'an Dios Awquejja,",
        "Nayajj jacañ munta.",
        "Jacañajjas Jumaruwa",
        "Wiñayatac churjjsma.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Cusisisaw nayajj k'ochü",
        "Juma Dios Awatirír.",
        "Naya laycuw Jumajj jiwta,",
        "Calvario cruzana. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Kollan Ajayump phokt'ita,",
        "Jumamp jacañatac.",
        "K'oma chuymay tucuyita,",
        "Jumar sirviñatac.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Ma uruw alajjpachanjja",
        "Jumampejj cusisl.",
        "Jan karjasisaw nayajja",
        "Jumarojj k'ochojja."
      ]
    }
  ]

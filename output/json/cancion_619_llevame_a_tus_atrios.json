      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Pasare en la muchedumbre",
        "Por dónde el sacerdote canta.",
        "Tengo hambre y sed de justicia",
        "Y sólo encuentro un lugar.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Llévame al lugar Santísimo",
        "Por la sangre del cordero redentor.",
        "Llévame al lugar Santísimo",
        "Tócame límpiame, heme aquí."
      ]

      "lineas": [
        "Chinkasqa almasta pusamuy Qan, Señor.",
        "/Qanta manaraj rejsisqankuwan",
        "Wañuyman rishanku./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Pusamuy Qan, Señor, amaña saqeychu.",
        "/Kawsayninkupi kusisqas kanku,",
        "Almanku Ilakisqas./"
      ]
    }
  ]

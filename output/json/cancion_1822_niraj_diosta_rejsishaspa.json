      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Kunanqa Diosta rejsispa, kusisqalla purikuni./",
        "/Graciasta qoni Diosniyman",
        "Chay jatun perdonninmanta./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Qanrí munasqa kawsaqe, Ilakiyilapichu kashanki?/",

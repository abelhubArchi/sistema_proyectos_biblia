  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Abre los cielos sobre nosotros",
        "Abre los cielos Señor, haz llover",
        "Somos tu pueblo, somos tu viña",
        "Abre los cielos Señor, haz llover"
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Los árboles del campo se han secado",
        "El vino y el aceite se acabó",
        "Tu viña está desierta y sin vallado",
        "En nuestro asolamiento hay un clamos",
        "Abre los cielos…"
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Vuélvenos, a ti nos volveremos",
        "Ven a darnos vida una vez más",
        "Vuélvenos de nuestro cautiverio",
        "Haz tu remanente regresar"
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Abre los cielos…",
        "Haz llover, haz llover",
        "Sobre tus renuevos, haz llover",
        "Haz llover, haz llover, haz llover Señor"
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 5,
      "lineas": [
        "/// Manda la lluvia, manda la lluvia",
        "Manda la lluvia, manda la lluvia ///"
      ]
    }
  ]

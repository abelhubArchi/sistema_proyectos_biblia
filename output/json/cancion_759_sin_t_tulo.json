      "lineas": [
        "Glorioso Salvador",
        "Divino redentor",
        "Me pos-tra-re, ante ti",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Bendito hijo de Dios",
        "Hermoso rey de Sion",
        "Te ado-ra-re, y así declarare",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Eres rey de los cielos, eterno Dios",
        "Exaltado por siempre, Jesús Señor",
        "Tú gobiernas en toda la creación",
        "Oh cordero inmolado, eres señor",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Las naciones enteras se postraran",
        "Y tu nombre por siempre bendecirán",
        "Por los siglos tu gloria, nos llenara",
        "Y veremos tu fuerza, y majestad"
      ]
    }
  ]

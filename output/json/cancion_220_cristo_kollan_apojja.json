  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Cristo Kollan Apojja Qhuyapayasiñamajj",
        "Aca khanar uñtataw chuymajjana khanasqui.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Wiñayaw arcama",
        "Cristo Tatitu,",
        "Jan khepar cuttasa",
        "Jiwañajjcama.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Take chuymajjampiwa thaquiman nayajj sara,",
        "Arunacam ist'asa alajjpacha marcaru.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Thaquiman sarañajja sinti cusisiñawa.",
        "Nayan asquejjataquiw khespiyatamajj Tatay.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Munasiñamajj Tatay sinti muspharcañawa,",
        "Naya juchan jakeru khespiyista ucata."
      ]
    }
  ]
}
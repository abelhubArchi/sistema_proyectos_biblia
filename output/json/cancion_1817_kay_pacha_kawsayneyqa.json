      "numero": 1,
      "lineas": [
        "/Kay pacha kawsayneyqa, Señor,",
        "T'ikaman rijch'akojlla kashan.",
        "Qhora jiña ch'akipojllataj,",
        "Llakisqalla kawsani./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Yachachiway Palabraykita,",
        "Ch'usaj sonqoílaraj kashani.",
        "Rinaypaj k'anchaj llajtaykiman",
        "Wakichiway, Señorniy./"
      ]
    }
  ]
}
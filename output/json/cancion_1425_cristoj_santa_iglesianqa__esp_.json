  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Los que somos de la Iglesia del Señor,",
        "Vivamos en gozo y en amor,",
        "Alabando al Señor./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Despertad, hermanos,",
        "Jesucristo ya viene.",
        "En las nubes El vendrá./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Cuantos en la maldad dormitando están,",
        "Pues velemos los que somos de El.",
        "Jesucristo ya viene./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Son millares que van a la perdición",
        "En las tinieblas vagando están,",
        "Por siempre perecerán./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "/Santo Espíritu redarguyendo está,",
        "A los que buscan la salvación.",
        "Será su Consolador./"
      ]
    }
  ]
}
      "lineas": [
        "/\"Ama manchachikuychu niwan Señor",
        "Atiyniyoj Diosniyki kani\"./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/”Mañakuway, noqa qosqayki;",
        "Mosoj willay yachachisqayki\"./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/\"Kallpachakuy, chanta wapuchakuytaj qan",
        "Kamachisniyta ama saqespa”./"
      ]
    }
  ]

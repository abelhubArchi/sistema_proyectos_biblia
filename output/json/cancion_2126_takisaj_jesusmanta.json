      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Takipusaj Jesusllapaj cruzpi wañusqanmanta",
        "Chay Calvario Orqopitaj yawarjich'asqanmanta.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Takisaj Jesusmanta Salvajniy kasqanta,",
        "k’anchashaj chay gloriampí Jesusman takisunchej.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Jesusneyqa orqhowarqa juchapi musphashajtiy,",
        "Qhuyaynimpi pusawarqa ovejasnin chaynejman",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Jesusllamin thañichiwan juchaj nanchachisqanta",
        "Juchaypa p'enqachiyninta Jesuslla orqhowarqa."
      ]
    }
  ]
}
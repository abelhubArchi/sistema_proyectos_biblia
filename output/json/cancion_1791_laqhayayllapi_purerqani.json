  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Laqhayayllapi purerqani",
        "Diosmanta chinkasqa.",
        "/Cristo niwarqa uj p’unchaypi:",
        "\"Chimpamuy, juchayoj”/",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Chaymantapacha Pay salvawan",
        "Tukuy juchaymanta.",
        "/Laqhayaypitaj uj k'anchayta",
        "Cristolla ruwawan./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Uj paqarimpi mask’awarqa",
        "Diosniypa kamachin.",
        "/Munakuynimpi Dios Tatayqa",
        "Mosojyachiwanña./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Kunantaj may kusisqa kani",
        "Diosniyta sirvispa.",
        "/Chay jatun munakuynimpitaj",
        "Payllata qhatisaj./"
      ]
    }
  ]
}
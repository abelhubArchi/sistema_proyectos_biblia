  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Señor Jesusniy noqawan kashan,",
        "Paylla noqata waqaychashawan./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Janaj pachapi mosoj llajtaqa;",
        "Uakiyilapuni kay pachapeqaj",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Señor Jesusqa waqaychashawan.",
        "Pantay ñanmanta Pay orqhowarqa./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Qallariymanta tukukuykama",
        "Señor Jesusqa kallpata qowan./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "/Mana rejsispa Jesucristota,",
        "Nina larwaypi ñak’arenqanku./"
      ]
    }
  ]
}
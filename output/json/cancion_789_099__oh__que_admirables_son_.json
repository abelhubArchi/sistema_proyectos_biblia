      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Llevó mis transgresiones,",
        "Él me santificó,",
        "Oyó mis peticiones,",
        "su sangre me sanó.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "¡Admirables obras las que me ha hecho Dios!",
        "¡Oh, cuan admirables son! ¡Admirables todas son!",
        "",
        "¡Admirables obras las que me ha hecho Dios!",
        "¡A su nombre loor!",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "En medio de aflicciones conmigo siempre está,",
        "Si asaltan tentaciones, El mi alma guardará.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Su bendición me sacia; Él me hace prosperar,",
        "Me da su gloria y gracia, me sabe acrisolar.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Me guarda fiel, por tanto, gozando estoy su amor;",
        "Mi gratitud le canto, y sirvo a mi Señor."
      ]
    }
  ]

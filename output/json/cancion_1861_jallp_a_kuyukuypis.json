  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Jallp'a kuyukuypis kachun,",
        "T’ukuna Ilakiypis kachun.",
        "/Ama manchikuychu, hermano,",
        "Kallpachakuy, sinch'i sayay./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Jesucristo jamojtenqa,",
        "Pusawasun Iglesianta.",
        "/Sinch'i qaylla chaypaj kashan.",
        "Chaypi wiñaypaj kawsasun./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Intipis yaykuponqaña,",
        "Ñak'arina tukukonqa.",
        "/Jaqay cielopi Cristowan",
        "Waqay, nanay tukukonqa./"
      ]
    }
  ]
}
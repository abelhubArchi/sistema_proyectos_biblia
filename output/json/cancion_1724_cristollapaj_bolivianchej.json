      "lineas": [
        "Cristollapaj BOLIVIANCHEJ kanqa,",
        "Paypaj ujchasqas llank'ajtinchej.",
        "Suyunchejtaj yupaychanqa Diosta,",
        "Tükuy rikonqa atiyninta.",
        "Kallpachasqas tukuy llojsinachej,",
        "Diosmanta willaramunachej.",
        "/Tukuynin rinachej Diosmanta",
        "Willaraj. Kutímonqaña Jesús./"
      ]
    }
  ]
}
  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "May kusisqasjaku, hermanos, janaj pachaman.",
        "Waj kawsaqestapis pusaspa Señor Jesusman.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Chimpaykunachej Señor Jesusman.",
        "Paymanta kallpata mañaspa ñawpajman riña./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "May kusisqa noqa kashani Khuyakojniywan.",
        "Paylla jatun Khuyakojneyqa, Paypi yuyani.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Supay pantachej jamojtenqa, Diosniy noqawan.",
        "Payqa k'anchashawanchejpuni tukuyninchejta."
      ]
    }
  ]
}
  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Estando aquí en Tu presencia,",
        "en la hermosura de Tu paz",
        "Tú tienes poder para sanarme,",
        "con sólo una palabra sano soy"
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Sanidad, en Su palabra hay sanidad,",
        "Sanidad y libertad"
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Yo espero en Ti en la promesa tuya oh Dios",
        "Tú hablas la palabra y sano yo soy",
        "Por Tu llaga hoy todos somos sanos",
        "y un milagro hay de sanidad"
      ]
    }
  ]
}
  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Santo runaspajqa Diospa llajtampeqa,",
        "Mana ujtawampis Ilakiy kanqachu.",
        "Cielo llajtapeqa Diosninchejwan khuska,",
        "Tukuy angeleswan kusikamusun.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "IMosoj Uajtapeqa tukuy unas tiyan,",
        "Trajina q'aparishaj llajtapU",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Kay jallp'a patapi waqay, phutiy tiyan;",
        "Mikhunasmantapis Ilakikunalla.",
        "Chayrayku, hermanos, Diosman qayllaykuna,",
        "Misk’aypis jamojtin, Dios noqanchejwan."
      ]
    }
  ]
}
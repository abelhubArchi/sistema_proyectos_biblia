  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Munakoj Salvador, Qan khuyawarqayku",
        "Kay wawasniykita./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Kusiy gloríaykipí pusaykachawayku",
        "Wiñaynintimpaj./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Munakuywan junfa k'acha sutiykeqa,",
        "Chhika khuyakoj Dios./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Palabrayki niwan Qanlla qowarqanki",
        "Wiñay bendicionta./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "/Wiñaypaj kawsasaj wañusqaykirayku,",
        "Khuyakoj Señorníy./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 5,
      "lineas": [
        "/Chimpamuyki, Señor, sinch^i munakuywan.",
        "Yupaychayki, Señor./"
      ]
    }
  ]
}
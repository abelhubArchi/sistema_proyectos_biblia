  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Sutíykita oqharispa, wiñaypajmin takisaj.",
        "Santo kanki, Cristo, yupaychasqayki./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Janaj pacha gloriapi Qan kawsanki, Señorníy",
        "Atiyniyoj kanki wiñay wiñaypaj./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Graciasta qoyki, Señor, salvawasqaykimanta.",
        "Qanllapaj takisaj wiñay wiñaypaj./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Nisqasniykeqa, Señor, wiñaynintimpaj kashan.",
        "Thkuywan ujchasqa kusikamusaj./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "/Kay pacha kawsaypeqa ch'eqerasqa kawsanchej.",
        "Janaj pachapiraj ujchasqas kasun./"
      ]
    }
  ]
}
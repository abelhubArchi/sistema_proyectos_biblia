      "lineas": [
        "¿Kawkha maras Tatitur arcta,",
        "Cunjamas jumataquejj?",
        "¿Cusisiñti churtam, llacfataquich jacasta?",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Tatitur sirvipjjañan, jupaquiw churistani",
        "Wiñay cusisiña alajjpach marcapana.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "¿Kawkha maras Tatitump jacta",

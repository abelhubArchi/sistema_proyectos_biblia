        "Jupan wawapjamay jacañamjja khantayam.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "¿Kawkha cutis arunacapar",
        "Jan yákasajj sarnakta?",
        "Amuyfasjjamaya arunacap isfasa.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Kollan Cristo perdonfapjjetay",
        "Juchaniw uñjasipjjta,",
        "Juman ch'amamampejj wiñayaw sirvipjjáma."
      ]

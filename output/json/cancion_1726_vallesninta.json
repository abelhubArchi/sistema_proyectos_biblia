      "lineas": [
        "Vallesninta, lomasninta takispa risaj.",
        "Señor Jesusniy waqaychashawan,",
        "Señor Jesusniy noqawan kashan.",
        "Tutas llakisqa kashajtiy, Pay kusichiwan,",
        "/Pay yanapawan, sumaj Salvador./",
        "/Munakuwan, perdonawan,",
        "Salvakuwan, kallpachawan.",
        "Rejsini munakuyninta mayllapipis noqawan./"
      ]
    }
  ]

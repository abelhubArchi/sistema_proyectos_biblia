      "lineas": [
        "/Señor Jesusníy, yanapaway,",
        "Tentaciompi kallpa qoway./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Janaj pachaman. Señor,",
        "Qanwan khuska noqa risaj,",
        "Jaqay cielopeqa qori wasiy tiyapuwan./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Señorllapajña llank’apusaj,",
        "Evangeliota willaspa./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Qori pilluta qopuwanqa,",
        "Jesusniy, llank'asqaymanta."
      ]
    }
  ]

  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Utat jayancañajj llaquisiñawa,",
        "Jan qhitin tumpata Awquit jayana;",
        "Sapac sarnakañajj aynacht'añawa",
        "Cunayman mutusa juchan sarnakas.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Cuttanjjamay wawa. Dios Awquimaru;",
        "Cunapachcamasa jayán jacáta. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Kolikemas korimas tucusiquiniw,",
        "Pist'añ horasajja camacht'atasa;",
        "Munat a mi gomas jaytanucütam,",
        "Janc'aquiy cuttanjjam munat utamar.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Ñankha jacañata mistunjjamaya;",
        "Llaquisiñaquiwa jumataquejja;",
        "Amuyt'asjjamaya utar cuttanjjañ,",
        "Awquimajj suyasctam munasiñampi.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Dios Tatitusajja jiwas munasaw",
        "Cristo Wawap churi khespiyañatac;",
        "lyawsan laycuquiw catokestani,",
        "Cruzan jiwatapar jaysañán ucajj."
      ]
    }
  ]
}
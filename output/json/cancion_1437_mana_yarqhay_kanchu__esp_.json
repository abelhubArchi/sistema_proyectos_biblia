      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Para los salvados no habrá más penurias,",
        "Ni dolor, ni llanto. ¡Qué felicidad!",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Cristo dio su vida allá en el Calvario.",
        "Derramó su sangre por mí, en la cruz./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Mientras tenga vida anhelo servirte.",
        "Consagro mi vida a Tí, buen Señor.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "El que en Jesús cree tendrá vida eterna.",
        "A Cristo hoy acude y salvo serás."
      ]
    }
  ]

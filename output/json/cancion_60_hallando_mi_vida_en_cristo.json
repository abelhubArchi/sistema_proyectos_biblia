{
  "numero": 60,
  "titulo": "HALLANDO MI VIDA EN CRISTO",
  "carpeta": "01 Himnario Iglesia de Dios",
  "tono": null,
  "compas": null,
  "autor": null,
  "compositor": null,
  "copyright": null,

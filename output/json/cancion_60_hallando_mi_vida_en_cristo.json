  "referencias_biblicas": [],
  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Paz perfecta yo busqué,",
        "Pero nunca la encontré,",
        "Pues el precio no quería yo pagar",
        "De mi Dios lejos vagué,",
        "Su promesa rechacé,",
        "Del pecado no queriéndome apartar.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Muerto al mundo, mas viviendo para ti,",
        "Esconderme quiero yo detrás de ti.",
        "Aunque sufra cruel dolor,",
        "Me prometas tu valor,",
        "Y hallaré por fin mi vida sólo en ti (sólo en ti).",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Mas estando en oración",
        "Dios tocó mi corazón",
        "Y me dijo: \"Pon tu todo en el altar.\"",
        "Al pecado renuncié,",
        "Del orgullo me aparté",
        "Y mi alma pudo El santificar.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Ya la sangre se aplicó",
        "Y mi ser purificó;",
        "Una vida de victoria vivo ya,",
        "Mis pecados perdonó,",
        "De mis luchas me libró;",
        "En Jesús encuentro mi felicidad."
      ]
    }
  ]
}
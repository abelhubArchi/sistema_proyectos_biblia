    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Cristoj chakisninman chimpaykamusaj,",
        "Salvacionninmanta graciasta qospa./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Diosman takisaj yupaychayninta.",
        "Runasman mllasaj salvacionmanta./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Diosniypa chajrampi noqa llank'asaj",
        "Kay laqha mundopi kawsanaykama./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Espíritu Santo pusawasunchej",
        "Señorpa chajrampi llank'ajkunata./"
      ]
    }
  ]
}
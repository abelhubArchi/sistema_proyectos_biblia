      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Cieloman ripunayqa ancha walejpunimin.",
        "Cristomin yanapajniy, Payllapi confíakusaj.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/May munakoj Señorníy, khuyakuyniyki jatun.",
        "Noqa juchasapata Qanlla salvawarqankU",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Juchapi kashateyqa, Ilakiy, nanaylla kawaj.",
        "Khuyakuynimpi Jesús salvacionta Pay qowan.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Kay pacha kawsayniypi wañupunaykamapis",
        "Tukuyman noqa nisaj Salvador kasqaykita."
      ]
    }
  ]
}
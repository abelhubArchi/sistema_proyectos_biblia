  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Yupaychanachej Señoría Hakiypi kusikuypi.",
        "Graciasta qona Señorman qhapaj, wajcha kaspapis/",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Graciasta qoyki, Señor, kay pacha kawsaymanta.",
        "Cruzpi wañusqaykirayku wiñay kawsay kapuwan/",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Peligropis qayllamojtín, Señorqa noqanchejwan.",
        "Llakiy, waqayjamojtimpis, Pay sonqochawajninchej./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Kallpayki pisiyapojtin, pajtá qan urmashawaj.",
        "Mañarikuy Diosllamanta, Paytaj kallpachasonqa./"
      ]
    }
  ]
}
        "GRANDE ES EL AMOR DE DIOS",
        "QUE MI VIDA ÉL TRANSFORMÓ",
        "Y POR ESE AMOR DE DIOS",
        "SALVO SOY, SALVO SOY.",
        "NADIE PUDO AMARME A MI",
        "NI ENTENDER LO QUE HABÍA EN MI.",
        "SÓLO POR EL AMOR DE DIOS"
      ]

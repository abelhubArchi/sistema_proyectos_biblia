  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "En las tinieblas de la maldad.",
        "Anduve sin mi Dios.",
        "Pero un día Cristo me dijo,",
        "\"Ven, pecador, a mí.\"",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Desde entonces me redimió",
        "De toda mi maldad.",
        "Una antorcha en las tinieblas",
        "Cristo me convirtió.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Una mañana me sorprendió",
        "Un siervo del Señor.",
        "Al recibir palabras de amor,",
        "Cristo me transformó.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Hoy ya me siento de El muy feliz,",
        "Con alma vibrante.",
        "Con esa dicha llena de amor,",
        "Que nunca olvidaré."
      ]
    }
  ]
}
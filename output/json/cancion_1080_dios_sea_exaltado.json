  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Dios sea exaltado,",
        "sus enemigos sean esparcidos.",
        "Penetrando en el reino de las tinieblas",
        "con alabanza.",
        "Subiré a las montañas,",
        "gritaré a las naciones",
        "Que el reino de las tinieblas",
        "está cayendo"
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Está cayendo, está cayendo,",
        "está cayendo, está cayendo",
        "Ya se ha caído"
      ]
    }
  ]
}
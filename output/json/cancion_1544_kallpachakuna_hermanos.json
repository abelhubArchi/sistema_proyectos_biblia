      "numero": 1,
      "lineas": [
        "/Kallpachakuna, hermanos, Cristo noqanchejwan.",
        "Tukuyninchej ujchasqas atipaj riña./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Capitanninchej Cristo atipallampuni,",
        "Payllapi confiakuspa atipasunchej./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Maqanakuna kashan Supaypa contrampi.",
        "Cristopi kallpa kashan atipanapaj./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Jap'ikunachej ari Diospa armasninta,",
        "Oraspa tuta p’unchay, Biblia leespa."
      ]
    }
  ]

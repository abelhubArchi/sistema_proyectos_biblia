      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Munakuwaj Jesusniy, noqarayku wañorqa.",
        "Juchasniyta qhechorqa yawarninta jich'aspa.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Gloria kachun Payman, gloria kachun Payman.",
        "Noqanchejwan payqa jark'akuwajninchej./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Noqanchejwan Pay kashan Paymanta mañakuna",
        "Takuy ima Diospajqa atikullanqapuni.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Na’ariypisjamojtin, Payllaman qhaparicuy.",
        "Waqay nanay kasojtin, Payllaman chimpaykukuy."
      ]
    }
  ]
}
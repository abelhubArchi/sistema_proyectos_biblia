      "lineas": [
        "/Llakiyniykipi takiy Diosllaman.",
        "Kusikuspa takejtíyki, Ilakiy riponqa./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Takishankichu, orashankichu ?",
        "Creespalla mañajtiyki, kusíy tarinki./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Nak’ariypipis oray sonqowan.",
        "Oraspalla kanki chayqa, Ilakiy riponqa./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Jesusman chimpay, yanapasonqa.",
        "Pruebaspipis kashajtiyki, sonqochasonqa./"
      ]
    }
  ]

  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Jinallachu Diosman risaj, makisniy ch'usajllachu,",
        "Ni uj almata pusaspa, nitaj allin sirvispa?",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "JinaUachu Diosman risaj, ch’usajllachu chuyasaj?",
        "Tiempoyta usuchispalla, imawaníaj chimpasaj?",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Ma wañuyta manchanichu, Cristoqa Salvawajniy;",
        "Ni Señorpaj llank’anichu, chaymá Ilakiy noqapaj.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Usuchini tíempoytaqa, Diosman mana qospalla;",
        "Purishaspa kay pachapi, Supayllaman qoj kani."
      ]
    }
  ]
}
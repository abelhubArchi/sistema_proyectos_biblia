  "referencias_biblicas": [],
  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Señor, Qan pusaway munakuyniykipi,",
        "Yawarniykiwantaj juchayta mayllaway.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Kunanmin tiempo kashan chimpaykunapaj,",
        "Tukuy sajra kawsayta saqepunapaj./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Tentación jamojtin, Qan kallpachariway,",
        "Atipachiwaytaj sajra kawsayniyta.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Janaj pachapeqa kusikuyila kanqa.",
        "Angeleswan khuska yupaychamusqayki.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Mayk’ajchus saqeyman kay pacha kawsayta",
        "Yanaparillaway, Qanwanña ripusaj."
      ]
    }
  ]
}
      "lineas": [
        "Kutímuspa Jesusqa tapusojtin ruwasqaykimanta,",
        "Ima ninki Payta tapusojtin talentomanta?",
        "Yapallaypuni arí, talentoykiman arí.",
        "Qan, hermanóy, yapay talentoykiman.",
        "Yapallaypuni, arí, yapallaypuni, arí,",
        "Cristo qosorqa, chayman yapay."
      ]
    }
  ]

      "numero": 1,
      "lineas": [
        "Alajjpachanquir suma Awquiy",
        "Mayisitajjar ist'aquitay.",
        "Cunaymani yant'anacawa",
        "Nayataquejja sartañ muñí",
        "Acá oraken.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Yanapt'asitay Dios Awquejja",
        "Llaquisiñajja horasana.",
        "Jachañajjatejj puritojja,",
        "Juma saparuquiw quillt'asma,",
        "Uywthapt'a sitay.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Munasinampiw nayar sistajj:",
        "—Janiquiy páchisimti —sasin.",
        "Qhuyapt'ayitay Dios Awquejja",
        "Asqui wawama tucuñatac",
        "Wiñayataqui."
      ]
    }
  ]

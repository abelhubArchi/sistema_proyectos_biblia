      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Heme aquí, oh Padre Dios",
        "Ten piedad de mí, Señor.",
        "Lléname de tu poder,",
        "Para que te siga fiel.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Guíame, oh Señor,",
        "En tu senda de luz,",
        "Y contigo feliz",
        "Hasta el fin seguiré.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Sólo por tu gran amor,",
        "Me salvaste del pecar.",
        "Por tan grande redención,",
        "Mi alabanza te daré.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Porque errados muchos van,",
        "Olvidando tu amor,",
        "Dame ayuda y poder",
        "Para hablar de Ti, Señor."
      ]
    }
  ]
}
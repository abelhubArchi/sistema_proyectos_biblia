  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Jumar sirviña nayajj amtasta, catokfasitay Cristojja.",
        "Acá chuymajjsa jumaruw chursma",
        "Juman jacjjañamataqui.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "K'oma chuyman Tatay nayar tucfayita,",
        "Kollan Ajayumamp phokt'araquitaya.",
        "Jacáwejjana, jumatacjama",
        "Samakañajjataqui. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Cayunacajjas cheka thaquiman sapürus sarnakaracpan.",
        "Amuyojjasa Kollana Cristo, jumjjataqui lup'iracpan.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Lacajjas Cristo arunacama khananchiriraquipanay.",
        "Arsutajjasa, uñtatajjasa jumar agradquiripanay.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Take urunsa Kollana Cristo, Jumaruquiw sirviñ munsma.",
        "Yanapfitaya tucuy urcama, jumar sirviñajjataqui."
      ]
    }
  ]
}
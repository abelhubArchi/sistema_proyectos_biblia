  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Wañorqa Jesús cruzpi noqaraykumin,",
        "Kawsayninta churarqa salvanawampaj.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Manuykitamin Jesús junfarqa",
        "Chay chhika millay cruzpi.",
        "Cristo] cruznímpi mosoj kawsayta",
        "Qan tarinki, hermanóy.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Qampaj Cristo wañorqa chay k'aspi cruzpi",
        "Chimpay arí Señorman kawsanaykipaj.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Santo Espíritu wajyan juchasapasta.",
        "Tiempo kashajtin, mask'ay, perdonasonqa.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Jesuspa chakisninman usqayta jamuy.",
        "Wiñaypajtaj kawsanki janaj pachapi."
      ]
    }
  ]
}
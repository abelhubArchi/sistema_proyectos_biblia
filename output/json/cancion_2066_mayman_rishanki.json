      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Mayman rishanki qan, runa masi?",
        "Laqhallapeqa chinkayman rinki.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Mañana kanqachu qhepaman perdompis,",
        "Cielo punkupis msq'akaponqa./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Kunanchus jamunman Jesucristoqa,",
        "Imanispataj Payta niwajri?/",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Qan runa masi juchapi kashanki,",
        "Jesucristopi tarinki perdonta./"
      ]
    }
  ]

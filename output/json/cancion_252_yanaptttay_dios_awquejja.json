  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Yanapt'itaya Dios Awquejja,",
        "Yant'anacawa muyuntitu.",
        "Jumaquiy Cristo, ch'amanchita,",
        "Nayan atipjañajjátaqui.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Yanapt'itaya Dios Awquejja;",
        "Acá llaquinacat apst'itay.",
        "Juman chekpach wawamáñ munta. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Acá llaquisiñ orakenjja",
        "Uñisitasa sarnakascsta,",
        "Jumaquiy Tata, yanapita,",
        "Acá oraken jacañajjan.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Supayajj atipjañ munitu,",
        "Janiw atipjayasiñ muncti.",
        "Jumaquiw ch'amanchitasmajja",
        "Yant'ar atipjañataquejja."
      ]
    }
  ]
}
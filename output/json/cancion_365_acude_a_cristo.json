  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Cristo es el Salvador, que buscándote está,",
        "Pronto acude a El, y acéptale hoy.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Hoy escucha a Jesús,",
        "A tu buen Salvador;",
        ":Pues ya tiempo no habrá,",
        "Y muy tarde será. (Bis)",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Debes hoy confesar tus pecados a Dios.",
        "El te perdonará, con su amor sin igual.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "El murió en la cruz por amarte a ti,",
        "Hoy acepta a Jesús, es tu gran Salvador.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "El bendito Señor esperándote está,",
        "El te quiere adoptar y su hijo serás."
      ]
    }
  ]
}
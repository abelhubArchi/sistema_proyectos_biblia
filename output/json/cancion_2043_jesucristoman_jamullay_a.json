      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Jesucristoman Jamullayña",
        "Noqachejwanmin Payqa kashan.",
        "Wajyashasunki munakuywan,",
        "\"Jampuy wawáy,\" nispa.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "May kusiy noqaykupaj kanqa,",
        "Qanwan janaj pachapi kayqa",
        "Ñawpaqeykipi, kusikuypi,",
        "Chay mñay kawsaypi.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Payllamin atín qosuytaqa",
        "Llakiyniykipi kusikuyta.",
        "üj kutitawan wajyasunki,",
        "Salvasuyta muñan.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Wajyasusqanta uyariwaj,",
        "Usqhayllataña chimpaykukuy.",
        "Ichapis q'aya qhepa kanman;",
        "Kunampacha chimpay."
      ]
    }
  ]

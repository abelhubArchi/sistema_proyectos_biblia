  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Gracias por la cruz, Dios",
        "Por el precio tu pagar",
        "Mi pecado y dolor, tu amor quito",
        "Dando gracias eternal",
        "Gracias por tu amor, Dios",
        "Por las manos que herí",
        "Pues tu rió me limpio y siento al fin",
        "Tu perdón y salvación"
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Digno eres Señor, en tu trono estas",
        "Coronado con poder, reinas con majestad",
        "Cristo, hijo de Dios, exaltado rey",
        "Moriste en la cruz en mi lugar",
        "Digno eres Señor"
      ]
    }
  ]
}
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Warawaran c'ajatapaw amtayitu",
        "Tatitojjan acapachar jutatapa.",
        "Warawaraw khantanisa yatiyána",
        "Khespiyirin acapachan nacitapa.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Belén marcanwa naciwayi",
        "Khespiyiri Jesusajja, má uyuna.",
        "üca Jesusaw khespiyitu;",
        "Juchajj laycu t'akhesisa jiwawayi.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Suma virgen Mariatwa naciwayi",
        "Dios Awquina qhitanita wawapajja.",
        "Juchararar munasawa sarakani",
        "Acapachar khespiyiri Jesusajja.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Ovejanac awatiri jakenacar",
        "Má angelaw cusisiña yatiyána.",
        "Muspharataw jutapjjána. yupaychiri,",
        "Khespiyirin nacitapa yatisina.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Magonacajj warawarar uñtasawa",
        "Jutapjjána Jesusaru yupaychiri.",
        "Jach'a rey Herodesajj mayjt'asinaw",
        "Khespiyirin nacitapa yatisina."
      ]
    }
  ]

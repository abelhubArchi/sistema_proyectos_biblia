  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Te loamos, oh Dios, con unánime voz.",
        "Que en Cristo tu Hijo nos diste perdón.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Aleluya, te alabamos, cuan grande es tu amor.",
        "Aleluya, te adoramos, bendito Señor.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Te loamos. Jesús, quien tu trono de luz",
        "Has dejado por damos salud en la cruz.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Te damos loor, santo Consolador,",
        "Que nos llenas de gozo y santo valor.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Te loamos, oh Dios, nuestras culpas pagó El.",
        "Por tu gracia nos concediste el perdón.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 5,
      "lineas": [
        "Unidos load, a la gran Trinidad,",
        "Que es la fuente de Gracia, virtud y verdad."
      ]
    }
  ]
}
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Ilumina, oh Padre, nuestros corazones.",
        "A Ti consagramos todo nuestro ser./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Todos los creyentes sigamos a Cristo,",
        "Nunca demos vuelta hacia atrás./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/A los que se pierden, llevemos a Cristo,",
        "Que van rumbo a la perdición./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "A los que vencieren los males del mundo,",
        "De los tales será la mansión./"
      ]
    }

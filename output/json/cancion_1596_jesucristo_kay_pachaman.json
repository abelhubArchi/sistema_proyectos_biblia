      "lineas": [
        "Jesucristo kay pachaman mask'aspajamorqa,",
        "Munakuywan wawastapis salvayta muñan.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Pusanachej Jesusman Pay munakun wawasta.",
        "K'anchanqanku Jesuspaj ch 'askasnin jiña.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Qori jiña k'ancharinku Jesuspa pillumpi,",
        "Yawarninwan Pay ranterqa creej wawasta.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Tukuy wawas chimpachunku Señor Jesusllaman.",
        "Paykunata munakuspa, cruzpi wañorqa."
      ]
    }

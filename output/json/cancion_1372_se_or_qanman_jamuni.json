  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Señor, Qanman jamuni, kawsayniyta qopuyki.",
        "Bendeciway, Dios Tatáy, pusawaytaj k’anchaypi./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Purimusaj llank'aspa, kasuspa Señorniyta,",
        "Evangelio mllaspa juchapi chinkasqasmanJ",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Kusikuywan takispa, Jesusniyta qhatisaj.",
        "Kallpata qoway, Señor, jucha atipanaypaj./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Wiñay kawsayta qowan cruzpi ñak’arisqanwan.",
        "Almaytapis llimphuchan janaj pacha llajtampaj./"
      ]
    }
  ]
}
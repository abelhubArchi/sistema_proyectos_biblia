      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Palabrayki tarpusqata wiñachiy ari, Señor;",
        "Qanlla atinki wiñachiyta atiyniykiwan, Señor.",
        "/Qanlla atinki poqochiytaqa, Señor./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Qanlla wajyay obrerosta, chajraykiman renqanku,",
        "Pusachunku ashkha almasta ñawpaqeykiman, Señor.",
        "/Iglesiayki parlachun Qanllamanta./"
      ]
    }
  ]
}
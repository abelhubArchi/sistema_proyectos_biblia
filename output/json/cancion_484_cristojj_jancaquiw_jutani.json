  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Acá jacañ orakejj jan walt’añanacansa,",
        "Llaquisiñanacansa phokhantataquiw.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Tatit Cristojja, niyaw jutani",
        "Jiwasanacar irpjjañataqui;",
        "Take chuymampí suyapjjañani",
        "Jan walinacar atipjasina.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "C’ari irpirinacas ch'amampiw sartaraqui,",
        "Criston wawanacapar mayjt'ayasina.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Ñankha lurañanacas juc'ampiw mirantarac;",
        "Cristor arquirinacas cutektapjjewa.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Tatit Cristojj ewjjestuw take wawanacapajj.",
        "Tucuycam thaquipana, sayt’añataqui."
      ]
    }
  ]
}
  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Kusikoyqa tiyapuwanqa",
        "Jesusniywan janaj pachapi.",
        "Nanaykuna, onqoykunapis",
        "Manañamin llakichiwanchu.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Ripusaj, ripusaj, ripusaj, Cristowan.",
        "Kay pachata saqesaj./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Dios Tatawan mana kanqachu",
        "Llakiykuna, phutiykunapis.",
        "Creejkuna kusikunachej",
        "May kusiywan Diosta sirvispa.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Tarimusaj janaj pachapi",
        "Wiñay wiñaypaj munakuyta.",
        "Jaqaypitaj tiyakamusaj",
        "Diospa jatun bendicionninwan.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "Kusikusaj janaj pachapi,",
        "Wiñay kusiy tiyapuwanqa.",
        "Cristollawan kusikamusaj,",
        "Wiñay wiñay Waqaychajniywan."
      ]
    }
  ]
}
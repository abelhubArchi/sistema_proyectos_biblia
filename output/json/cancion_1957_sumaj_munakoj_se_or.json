  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Sumaj munakoj Señor, khuyakuway, Dios Tatáy.",
        "Yachachiway noqaman evangelioykimanta.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Pusaway, Dios Tatáy, kallpaykita qoway.",
        "Kamachisqaykita risaj mllamusaj.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "Pusallaway, Dios Tatáy, Santo Espirituykiwan.",
        "Chay munakuyniykita willamusaj runasman.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Graciasta qoyki, Diosníy, munakuyniykimanta.",
        "Wiñaypaj sirvisqayki mosoj takiykunawan."
      ]
    }
  ]
}
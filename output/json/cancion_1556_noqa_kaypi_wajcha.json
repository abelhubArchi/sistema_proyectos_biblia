  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Noqa kaypi wajcha purishajtíy,",
        "Dios Tatáy, Qanlla k'anchaykuwanki./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Almaypa kamaynenqa",
        "Maymaníaj kunan rínman,",
        "Cristoman mana chimpayman chayqa?/",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Sumaj yuyaypi Qan kawsachiway",
        "K'anchay ñanninta purikunaypaj./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Munasqa Dios Tatáy, chimpamuyki,",
        "Jap'ikapuway makisniykipi./"
      ]
    }
  ]
}
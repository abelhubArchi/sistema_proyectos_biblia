  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Hay nuevas buenas que anunciar",
        "Al mundo en perdición,",
        "Son nuevas de gran gozo y paz,",
        "De gracia y salvación.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "Gran gozo hay, que viene del Señor;",
        "Gran gozo hay, que nos manda El en su amor.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "De fuentes de gozo eternal",
        "Las fuerzas Dios nos da;",
        "De gozo, de la salvación,",
        "Cantando mi alma está.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Dichosa el alma que el Señor",
        "Cual oro refino;",
        "Del gozo que el Señor nos dio",
        "Profunda paz brotó.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 4,
      "lineas": [
        "En este mundo de maldad",
        "Por Cristo viviré;",
        "Su paz que guarda el corazón",
        "Por siglos gozaré."
      ]
    }
  ]
}
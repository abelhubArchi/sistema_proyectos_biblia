      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "/Dios Tatáy, Qan uyarimuway.",
        "Qanllata qhatiyta yanapariway./",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Palabraykeqa, Señor,",
        "Ancha sumaj misk'imin.",
        "Munakuyniykimanta",
        "Yachachishawan./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "/Kay pachapi qhapaj kayneyqa,",
        "Qolqepis, qoripis tukukaponqa./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "/Kay pachapi k'acha t'ikaspis",
        "Intíwan ruphasqa wañurapullan./"
      ]
    }
  ]
}
  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "El bendito Cristo volverá muy pronto,",
        "Y los redimidos se los llevará.",
        "Los que fueron fieles y los que durmieron",
        "Serán levantados al celeste hogar.",
        ""
      ]
    },
    {
      "tipo": "coro",
      "lineas": [
        "/Esperad al Señor, al Señor esperad,",
        "Pues, estad alertas, ya vuelve el Señor./",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "El bendito Cristo nos dará encuentro,",
        "A sus santos fieles en las nubes ya.",
        "Luego gozaremos entre redimidos,",
        "De la vida eterna, en celeste hogar.",
        ""
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 3,
      "lineas": [
        "Jesucristo vuelve, dice su Palabra,",
        "En cualquier momento de imprevisión.",
        "Todos los hermanos, ya no cederemos,",
        "Nunca al pecado, ni a la tentación."
      ]
    }
  ]
}
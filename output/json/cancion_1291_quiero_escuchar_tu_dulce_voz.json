  "secciones": [
    {
      "tipo": "estrofa",
      "numero": 1,
      "lineas": [
        "Quiero escuchar tu dulce voz",
        "Rompiendo el silencio en mi ser",
        "Sé que me harías estremecer",
        "Me harías llorar o reír",
        "Caería rendido ante ti"
      ]
    },
    {
      "tipo": "estrofa",
      "numero": 2,
      "lineas": [
        "No podría estar ante ti",
        "escuchándote hablar",
        "sin llorar como un niño",
        "Pasaría el tiempo así",
        "sin querer nada más",
        "Nada más que escucharte hablar"
      ]
    }
  ]
}